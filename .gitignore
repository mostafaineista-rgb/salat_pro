android/app/src/main/res/raw/*.aac
android/app/src/main/res/raw/*.wav
android/app/src/main/res/raw/*.ogg

# IDE
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# JVM / Gradle crash dumps (often created in project dir on OOM)
